{
  "manifest_version": 3,
  "name": "川师教务顶栏与考试打印修复",
  "version": "3.5.0",
  "description": "修复四川师范大学教务系统顶栏无法切换，以及考试页面旧式 LODOP 打印、预览、导出 PDF 失效的问题。",
  "permissions": [
    "debugger",
    "downloads"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://202.115.194.60/Index.aspx*"],
      "js": ["webforms-patch.js"],
      "run_at": "document_start",
      "all_frames": true,
      "world": "MAIN"
    },
    {
      "matches": ["http://202.115.194.60/ExamManage/*"],
      "js": ["bridge.js"],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": ["http://202.115.194.60/ExamManage/*"],
      "js": ["exam-print.js"],
      "run_at": "document_start",
      "all_frames": true,
      "world": "MAIN"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "sicnu-webforms-fix@local",
      "strict_min_version": "128.0"
    }
  }
}

{
  "manifest_version": 3,
  "name": "川师教务顶栏与考试打印修复",
  "version": "3.7.0",
  "description": "修复四川师范大学教务系统顶栏无法切换，以及考试/打印页面旧式 LODOP 打印、预览、导出 PDF 失效的问题。",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    },
    "default_title": "川师教务修复"
  },
  "content_scripts": [
    {
      "matches": ["http://202.115.194.60/Index.aspx*"],
      "js": ["webforms-patch.js"],
      "run_at": "document_start",
      "all_frames": true,
      "world": "MAIN"
    },
    {
      "matches": [
        "http://202.115.194.60/ExamManage/*",
        "http://202.115.194.60/SelfPrint/*"
      ],
      "js": ["exam-print.js"],
      "run_at": "document_start",
      "all_frames": true,
      "world": "MAIN"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "sicnu-webforms-fix@local",
      "strict_min_version": "128.0"
    }
  }
}
